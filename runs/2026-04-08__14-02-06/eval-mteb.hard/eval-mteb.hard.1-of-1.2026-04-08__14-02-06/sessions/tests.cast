[12.632212, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_mteb_performance\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Search recursively for STS12.json files in the results directory\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        results_dir = \u001b[33m\"\u001b[39;49;00m\u001b[33m/app/results\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        found_valid_result = \u001b[94mFalse\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mfor\u001b[39;49;00m root, _, files \u001b[95min\u001b[39;49;00m os.walk(results_dir):\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mif\u001b[39;49;00m \u001b[33m\"\u001b[39;49;00m\u001b[33mSTS12.json\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m \u001b[95min\u001b[39;49;00m files:\u001b[90m\u001b[39;49;00m\r\n"]
[12.632239, "o", "                path = os.path.join(root, \u001b[33m\"\u001b[39;49;00m\u001b[33mSTS12.json\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mwith\u001b[39;49;00m \u001b[96mopen\u001b[39;49;00m(path, \u001b[33m\"\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n                    results = json.load(f)\u001b[90m\u001b[39;49;00m\r\n                    \u001b[94mif\u001b[39;49;00m results[\u001b[33m\"\u001b[39;49;00m\u001b[33mscores\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m][\u001b[33m\"\u001b[39;49;00m\u001b[33mtest\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m][\u001b[94m0\u001b[39;49;00m][\u001b[33m\"\u001b[39;49;00m\u001b[33mcosine_spearman\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m] > \u001b[94m0.7\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n                        found_valid_result = \u001b[94mTrue\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                        \u001b[94mbreak\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[12.632378, "o", "    \u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m found_valid_result, \u001b[33m\"\u001b[39;49;00m\u001b[33mNo STS12.json file found with cosine_spearman > 0.7\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: No STS12.json file found with cosine_spearman > 0.7\u001b[0m\r\n\u001b[1m\u001b[31mE       assert False\u001b[0m\r\n"]
