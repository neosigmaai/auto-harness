[13.745679, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_multi_branch_https_deploy\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n        \u001b[96mopen\u001b[39;49;00m(\u001b[33m\"\u001b[39;49;00m\u001b[33mverify.sh\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mw\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m).write(\u001b[33m\"\"\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m#!/bin/bash\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mset -e\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33mapt-get update\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mDEBIAN_FRONTEND=noninteractive apt-get install -y curl expect git openssh-client\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33mmkdir -p ~/.ssh\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mecho \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mHost localhost\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    StrictHostKeyChecking no\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    UserKnownHostsFile=/dev/null\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m > ~/.ssh/config\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mchmod 600 ~/.ssh/config\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m# Expect script to push both branches\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n"]
[13.74571, "o", "    \u001b[33mcat > git_push.exp << \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mEOF\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m#!/usr/bin/expect -f\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mset timeout 20\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33mspawn git clone git@localhost:/git/project project-test\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mexpect \u001b[39;49;00m\u001b[33m{\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33myes/no\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m \u001b[39;49;00m\u001b[33m{\u001b[39;49;00m\u001b[33m send \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33myes\u001b[39;49;00m\u001b[33m\\\\\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m; exp_continue }\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mpassword:\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m \u001b[39;49;00m\u001b[33m{\u001b[39;49;00m\u001b[33m send \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mpassword\u001b[39;49;00m\u001b[33m\\\\\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m }\u001b[39;49;00m\u001b[33m\u001b[39;49;00m"]
[13.745751, "o", "\r\n    \u001b[33m}\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mexpect eof\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m# main branch\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mspawn bash -c \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mcd project-test && \u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\r\n"]
[13.745776, "o", "    \u001b[33m                git checkout -b main && \u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\r\n    \u001b[33m                echo \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mmain branch content\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m > index.html && \u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\r\n    \u001b[33m                git add index.html && \u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\r\n    \u001b[33m                git config user.email \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mmain@example.com\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m && \u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\r\n    \u001b[33m                git config user.name \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mMain Dev\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m && \u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\r\n    \u001b[33m                git commit -m \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mmain commit\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n"]
[13.745792, "o", "    \u001b[33mexpect eof\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33mspawn bash -c \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mcd project-test && git push origin main\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mexpect \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mpassword:\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n"]
[13.745824, "o", "    \u001b[33msend \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mpassword\u001b[39;49;00m\u001b[33m\\\\\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mexpect eof\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n"]
[13.745982, "o", "    \u001b[33m# dev branch\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mspawn bash -c \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mcd project-test && \u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\r\n    \u001b[33m               git checkout -b dev && \u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\r\n    \u001b[33m               echo \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mdev branch content\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m > index.html && \u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\r\n    \u001b[33m               git commit -am \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mdev commit\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mexpect eof\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n"]
[13.746019, "o", "    \u001b[33mspawn bash -c \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mcd project-test && git push origin dev\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mexpect \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mpassword:\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33msend \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mpassword\u001b[39;49;00m\u001b[33m\\\\\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mexpect eof\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33mexit\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mEOF\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33mchmod +x git_push.exp\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m./git_push.exp\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m# Give nginx time to update\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33msleep 3\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33mMAIN=$(curl -sk https://localhost:8443/index.html)\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mDEV=$(curl -sk https://localhost:8443/dev/index.html)\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33mif [ \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m$MAIN\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m = \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mmain branch content\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m ] && [ \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m$DEV\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m = \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mdev branch content\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m ]; then\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m  echo \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mTEST PASSED\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33melse\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m  echo \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mTEST FAILED\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m  [ \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m$MAIN\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m != \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mmain branch content\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m ] && \u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\r\n    \u001b[33m    echo \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mExpected main: \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mmain branch content\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m, got: $MAIN\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m  [ \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m$DEV\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m != \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mdev branch content\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m ] && \u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\r\n    \u001b[33m    echo \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mExpected dev: \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mdev branch content\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m, got: $DEV\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m  exit 1\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mfi\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\"\"\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        time.sleep(\u001b[94m1\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        result = os.popen(\u0