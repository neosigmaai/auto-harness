[17.479243, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_makefile_compilation_process\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Verify that the Makefile works by running make clean and make.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mimport\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[04m\u001b[96msubprocess\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# First run make clean\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        clean_result = subprocess.run(\u001b[90m\u001b[39;49;00m\r\n            [\u001b[33m\"\u001b[39;49;00m\u001b[33mmake\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mclean\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m], cwd=\u001b[96mstr\u001b[39;49;00m(AGENT_WORKDIR), capture_output=\u001b[94mTrue\u001b[39;49;00m, text=\u001b[94mTrue\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m clean_result.returncode == \u001b[94m0\u001b[39;49;00m, (\u001b[90m\u001b[39;49;00m\r\n"]
[17.479294, "o", "            \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mmake clean failed with error: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mclean_result.stderr\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: make clean failed with error: make: *** No rule to make target 'clean'.  Stop.\u001b[0m\r\n\u001b[1m\u001b[31mE         \u001b[0m\r\n\u001b[1m\u001b[31mE       assert 2 == 0\u001b[0m\r\n\u001b[1m\u001b[31mE        +  where 2 = CompletedProcess(args=['make', 'clean'], returncode=2, stdout='', stderr=\"make: *** No rule to make target 'clean'.  Stop.\\n\").returncode\u001b[0m\r\n\r\n"]
