[17.478728, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_target_executable_was_created_and_is_executable\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Verify that the 'test_program' executable was created and is executable.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m TARGET_EXECUTABLE_PATH.exists(), (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mThe target executable \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mTARGET_EXECUTABLE_PATH\u001b[33m}\u001b[39;49;00m\u001b[33m was not created.\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: The target executable /app/test_program was not created.\u001b[0m\r\n\u001b[1m\u001b[31mE       assert False\u001b[0m\r\n"]
