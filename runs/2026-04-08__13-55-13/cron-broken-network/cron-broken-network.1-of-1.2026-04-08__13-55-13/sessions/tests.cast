[72.869789, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_curl_file_content\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n        time.sleep(\u001b[94m60\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        os.popen(\u001b[33m\"\u001b[39;49;00m\u001b[33m/usr/bin/curl example.com > /app/example.html\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m).read()\u001b[90m\u001b[39;49;00m\r\n        text = \u001b[96mopen\u001b[39;49;00m(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/example.html\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m).read()\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        ok = \u001b[94m0\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mfor\u001b[39;49;00m line \u001b[95min\u001b[39;49;00m content.split(\u001b[33m\"\u001b[39;49;00m\u001b[33m\\n\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m):\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mif\u001b[39;49;00m line \u001b[95min\u001b[39;49;00m text:\u001b[90m\u001b[39;49;00m\r\n                ok += \u001b[94m1\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
[72.869903, "o", "        \u001b[90m# Just incase example.com changes in the future\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m ok / \u001b[96mlen\u001b[39;49;00m(content.split(\u001b[33m\"\u001b[39;49;00m\u001b[33m\\n\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)) > \u001b[94m0.9\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mDid not read correct example content\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: Did not read correct example content\u001b[0m\r\n\u001b[1m\u001b[31mE       assert (2 / 46) > 0.9\u001b[0m\r\n\u001b[1m\u001b[31mE        +  where 46 = len(['<!doctype html>', '<html>', '<head>', '    <title>Example Domain</title>', '', '    <meta charset=\"utf-8\" />', ...])\u001b[0m\r\n\u001b[1m\u001b[31mE        +    where ['<!doctype html>', '<html>', '<head>', '    <title>Example Domain</title>', '', '    <meta charset=\"utf-8\" />', ...] = <built-in method split of str object at 0x28a719b0>('\\n')\u001b[0m\r\n\u001b[1m\u001b[31mE        +      where <built-in method split of str object at 0x28a719b0> = '<!doctype html>\\n<html>\\n<head>\\n    <title>Example Domain</title>\\n\\n    <meta charset=\"utf-8\" />\\n    <meta http-eq...sion.</p>\\n    <p><a href=\"https://www.iana.org/domains/example\">More information...</a></p>\\n</div>\\n</body>\\n</html>'.split\u001b[0m\r\n\r\n"]
