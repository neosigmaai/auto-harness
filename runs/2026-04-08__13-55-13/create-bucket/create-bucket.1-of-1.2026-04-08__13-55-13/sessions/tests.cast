[12.555566, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_bucket_exists\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test that the sample-bucket exists.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        s3 = boto3.client(\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33ms3\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            endpoint_url=LOCALSTACK_ENDPOINT,\u001b[90m\u001b[39;49;00m\r\n            aws_access_key_id=\u001b[33m\"\u001b[39;49;00m\u001b[33mtest\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            aws_secret_access_key=\u001b[33m\"\u001b[39;49;00m\u001b[33mtest\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m"]
[12.555633, "o", "\r\n            region_name=\u001b[33m\"\u001b[39;49;00m\u001b[33mus-east-1\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        response = s3.list_buckets()\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
[12.555742, "o", "        \u001b[90m# Extract bucket info\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        buckets = []\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mfor\u001b[39;49;00m bucket \u001b[95min\u001b[39;49;00m response[\u001b[33m\"\u001b[39;49;00m\u001b[33mBuckets\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m]:\u001b[90m\u001b[39;49;00m\r\n            buckets.append(\u001b[90m\u001b[39;49;00m\r\n                {\u001b[33m\"\u001b[39;49;00m\u001b[33mname\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: bucket[\u001b[33m\"\u001b[39;49;00m\u001b[33mName\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m], \u001b[33m\"\u001b[39;49;00m\u001b[33mcreation_date\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: bucket[\u001b[33m\"\u001b[39;49;00m\u001b[33mCreationDate\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m]}\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m \u001b[33m\"\u001b[39;49;00m\u001b[33msample-bucket\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m \u001b[95min\u001b[39;49;00m [bucket[\u001b[33m\"\u001b[39;49;00m\u001b[33mname\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m] \u001b[94mfor\u001b[39;49;00m bucket \u001b[95min\u001b[39;49;00m buckets], (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mBucket \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33msample-bucket\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m does not exist\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m"]
[12.555756, "o", "\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: Bucket 'sample-bucket' does not exist\u001b[0m\r\n\u001b[1m\u001b[31mE       assert 'sample-bucket' in []\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:27: AssertionError\r\n\u001b[31m\u001b[1m__________________________________________________________________ test_bucket_public_access ___________________________________________________________________\u001b[0m\r\n\r\n"]
[12.556877, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_bucket_public_access\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test that the bucket has public access enabled via either ACL or policy.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        s3 = boto3.client(\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33ms3\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            endpoint_url=LOCALSTACK_ENDPOINT,\u001b[90m\u001b[39;49;00m\r\n            aws_access_key_id=\u001b[33m\"\u001b[39;49;00m\u001b[33mtest\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            aws_secret_access_key=\u001b[33m\"\u001b[39;49;00m\u001b[33mtest\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            region_name=\u001b[33m\"\u001b[39;49;00m\u001b[33mus-east-1\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m"]
[12.556951, "o", "\r\n    \u001b[90m\u001b[39;49;00m\r\n        public_access = \u001b[94mFalse\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Check bucket ACL\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mtry\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n            acl = s3.get_bucket_acl(Bucket=\u001b[33m\"\u001b[39;49;00m\u001b[33msample-bucket\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m"]
[12.556972, "o", "\r\n            \u001b[94mfor\u001b[39;49;00m grant \u001b[95min\u001b[39;49;00m acl.get(\u001b[33m\"\u001b[39;49;00m\u001b[33mGrants\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, []):\u001b[90m\u001b[39;49;00m\r\n                grantee = grant.get(\u001b[33m\"\u001b[39;49;00m\u001b[33mGrantee\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, {})\u001b[90m\u001b[39;49;00m\r\n                all_users_uri = \u001b[33m\"\u001b[39;49;00m\u001b[33mhttp://acs.amazonaws.com/groups/global/AllUsers\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n                \u001b[94mif\u001b[39;49;00m (\u001b[90m\u001b[39;49;00m\r\n                    grantee.get(\u001b[33m\"\u001b[39;49;00m\u001b[33mType\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m) == \u001b[33m\"\u001b[39;49;00m\u001b[33mGroup\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                    \u001b[95mand\u001b[39;49;00m grantee.get(\u001b[33m\"\u001b[39;49;00m\u001b[33mURI\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m) == all_users_uri\u001b[90m\u001b[39;49;00m\r\n                    \u001b[95mand\u001b[39;49;00m grant.get(\u001b[33m\"\u001b[39;49;00m\u001b[33mPermission\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m) == \u001b[33m\"\u001b[39;49;00m\u001b[33mREAD\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                ):\u001b[90m\u001b[39;49;00m\r\n          "]
[12.556983, "o", "          public_access = \u001b[94mTrue\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                    \u001b[94mbreak\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mexcept\u001b[39;49;00m ClientError:\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mpass\u001b[39;49;00m  \u001b[90m# Continue to policy check if ACL check fails\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Check bucket policy if ACL check didn't confirm public access\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m public_access:\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mtry\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n                bucket_policy = s3.get_bucket_policy(Bucket=\u001b[33m\"\u001b[39;49;00m\u001b[33msample-bucket\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n                policy = bucket_policy.get(\u001b[33m\"\u001b[39;49;00m\u001b[33mPolicy\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mif\u001b[39;49;00m (\u001b[90m\u001b[39;49;00m\r\n"]
