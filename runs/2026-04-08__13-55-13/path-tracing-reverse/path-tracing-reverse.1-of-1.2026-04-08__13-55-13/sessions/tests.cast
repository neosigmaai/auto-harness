[18.894221, "o", "\u001b[31m\u001b[1m_____________________________________________________________________ test_image_c_exists ______________________________________________________________________\u001b[0m\r\n\r\n"]
[18.925641, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_image_c_exists\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n        image_c_path = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/mystery.c\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m image_c_path.exists(), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mFile \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mimage_c_path\u001b[33m}\u001b[39;49;00m\u001b[33m does not exist\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
