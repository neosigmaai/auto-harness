[5.217847, "o", "    \u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m \u001b[96misinstance\u001b[39;49;00m(handle, \u001b[96mstr\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n            handles.append(handle)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94melif\u001b[39;49;00m \u001b[96misinstance\u001b[39;49;00m(handle, \u001b[96mstr\u001b[39;49;00m):\u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Check whether the filename is to be opened in binary mode.\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Binary mode does not support 'encoding' and 'newline'.\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[5.217916, "o", "            \u001b[94mif\u001b[39;49;00m ioargs.encoding \u001b[95mand\u001b[39;49;00m \u001b[33m\"\u001b[39;49;00m\u001b[33mb\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m \u001b[95min\u001b[39;49;00m ioargs.mode:\u001b[90m\u001b[39;49;00m\r\n                \u001b[90m# Encoding\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>               handle = \u001b[96mopen\u001b[39;49;00m(\u001b[90m\u001b[39;49;00m\r\n"]
[5.217935, "o", "                    handle,\u001b[90m\u001b[39;49;00m\r\n                    ioargs.mode,\u001b[90m\u001b[39;49;00m\r\n                    encoding=ioargs.encoding,\u001b[90m\u001b[39;49;00m\r\n                    errors=errors,\u001b[90m\u001b[39;49;00m\r\n                    newline=\u001b[33m\"\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                )\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE               FileNotFoundError: [Errno 2] No such file or directory: '/app/books.csv'\u001b[0m\r\n\r\n"]
[5.217998, "o", "\u001b[1m\u001b[31m/usr/local/lib/python3.13/site-packages/pandas/io/common.py\u001b[0m:926: FileNotFoundError\r\n"]
[5.218038, "o", "\u001b[31m\u001b[1m______________________________________________________________________ test_data_accuracy ______________________________________________________________________\u001b[0m\r\n\r\n"]
[5.218303, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_data_accuracy\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test the accuracy of scraped data\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>       df = pd.read_csv(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/books.csv\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n             ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\u001b[90m\u001b[39;49;00m\r\n\r\n"]
[5.218347, "o", "\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:54: \r\n_ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ \r\n"]
[5.21841, "o", "\u001b[1m\u001b[31m/usr/local/lib/python3.13/site-packages/pandas/io/parsers/readers.py\u001b[0m:873: in read_csv\r\n"]
[5.218628, "o", "    \u001b[0m\u001b[94mreturn\u001b[39;49;00m _read(filepath_or_buffer, kwds)\u001b[90m\u001b[39;49;00m\r\n           ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31m/usr/local/lib/python3.13/site-packages/pandas/io/parsers/readers.py\u001b[0m:300: in _read\r\n"]
[5.218971, "o", "    \u001b[0mparser = TextFileReader(filepath_or_buffer, **kwds)\u001b[90m\u001b[39;49;00m\r\n             ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31m/usr/local/lib/python3.13/site-packages/pandas/io/parsers/readers.py\u001b[0m:1645: in __init__\r\n"]
[5.219293, "o", "    \u001b[0m\u001b[96mself\u001b[39;49;00m._engine = \u001b[96mself\u001b[39;49;00m._make_engine(f, \u001b[96mself\u001b[39;49;00m.engine)\u001b[90m\u001b[39;49;00m\r\n                   ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31m/usr/local/lib/python3.13/site-packages/pandas/io/parsers/readers.py\u001b[0m:1904: in _make_engine\r\n"]
[5.219411, "o", "    \u001b[0m\u001b[96mself\u001b[39;49;00m.handles = get_handle(\u001b[90m\u001b[39;49;00m\r\n_ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ \r\n\r\n"]
[5.219427, "o", "path_or_buf = '/app/books.csv', mode = 'r'\r\n"]
[5.219455, "o", "\r\n"]
[5.224043, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mget_handle\u001b[39;49;00m(\u001b[90m\u001b[39;49;00m\r\n        path_or_buf: FilePath | BaseBuffer,\u001b[90m\u001b[39;49;00m\r\n        mode: \u001b[96mstr\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n        *,\u001b[90m\u001b[39;49;00m\r\n        encoding: \u001b[96mstr\u001b[39;49;00m | \u001b[94mNone\u001b[39;49;00m = \u001b[94mNone\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n"]
[5.224083, "o", "        compression: CompressionOptions | \u001b[94mNone\u001b[39;49;00m = \u001b[94mNone\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n        memory_map: \u001b[96mbool\u001b[39;49;00m = \u001b[94mFalse\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n        is_text: \u001b[96mbool\u001b[39;49;00m = \u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n"]
[5.2241, "o", "        errors: \u001b[96mstr\u001b[39;49;00m | \u001b[94mNone\u001b[39;49;00m = \u001b[94mNone\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n        storage_options: StorageOptions | \u001b[94mNone\u001b[39;49;00m = \u001b[94mNone\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n    ) -> IOHandles[\u001b[96mstr\u001b[39;49;00m] | IOHandles[\u001b[96mbytes\u001b[39;49;00m]:\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m\r\n    \u001b[33m    Get file handle for given path/buffer and mode.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    Parameters\u001b[39;49;00m\r\n"]
[5.224168, "o", "    \u001b[33m    ----------\u001b[39;49;00m\r\n    \u001b[33m    path_or_buf : str or file handle\u001b[39;49;00m\r\n    \u001b[33m        File path or object.\u001b[39;49;00m\r\n    \u001b[33m    mode : str\u001b[39;49;00m\r\n    \u001b[33m        Mode to open path_or_buf with.\u001b[39;49;00m\r\n    \u001b[33m    encoding : str or None\u001b[39;49;00m\r\n    \u001b[33m        Encoding to use.\u001b[39;49;00m\r\n    \u001b[33m    compression : str or dict, default 'infer'\u001b[39;49;00m\r\n    \u001b[33m        For on-the-fly compression of the output data. If 'infer' and 'path_or_buf'\u001b[39;49;00m\r\n    \u001b[33m        is path-like, then detect compression from the following extensions: '.gz',\u001b[39;49;00m\r\n    \u001b[33m        '.bz2', '.zip', '.xz', '.zst', '.tar', '.tar.gz', '.tar.xz' or '.tar.bz2'\u001b[39;49;00m\r\n    \u001b[33m        (otherwise no compression).\u001b[39;49;00m\r\n    \u001b[33m        Set to ``None`` for no compression.\u001b[39;49;00m\r\n    \u001b[33m        Can also be a dict with key ``'method'`` set\u001b[39;49;00m\r\n    \u001b[33m        to one of {``'zip'``, ``'gzip'``, ``'bz2'``, ``'zstd'``, ``'xz'``, ``'tar'``}\u001b[39;49;00m\r\n    \u001b["]
[5.224186, "o", "33m        and other key-value pairs are forwarded to\u001b[39;49;00m\r\n    \u001b[33m        ``zipfile.ZipFile``, ``gzip.GzipFile``,\u001b[39;49;00m\r\n    \u001b[33m        ``bz2.BZ2File``, ``zstandard.ZstdCompressor``, ``lzma.LZMAFile`` or\u001b[39;49;00m\r\n    \u001b[33m        ``tarfile.TarFile``, respectively.\u001b[39;49;00m\r\n    \u001b[33m        As an example, the following could be passed for faster compression and to\u001b[39;49;00m\r\n    \u001b[33m        create a reproducible gzip archive:\u001b[39;49;00m\r\n    \u001b[33m        ``compression={'method': 'gzip', 'compresslevel': 1, 'mtime': 1}``.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m           May be a dict with key 'method' as compression mode\u001b[39;49;00m\r\n    \u001b[33m           and other keys as compression options if compression\u001b[39;49;00m\r\n    \u001b[33m           mode is 'zip'.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m           Passing compression options as keys in dict is\u001b[39;49;00m\r\n    \u001b[33m           supported for compression modes 'gzip', 'bz2', 'zstd' and 'zip'.\u001b[39;49;00m\r\n"]
[5.224192, "o", "    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    memory_map : bool, default False\u001b[39;49;00m\r\n    \u001b[33m        See parsers._parser_params for more information. Only used by read_csv.\u001b[39;49;00m\r\n    \u001b[33m    is_text : bool, default True\u001b[39;49;00m"]
[5.224198, "o", "\r\n"]
[5.224205, "o", "    \u001b[33m        Whether the type of the content passed to the file/buffer is string or\u001b[39;49;00m\r\n"]
[5.224259, "o", "    \u001b[33m        bytes. This is not the same as `\"b\" not in mode`. If a string content is\u001b[39;49;00m\r\n    \u001b[33m        passed to a binary file/buffer, a wrapper is inserted.\u001b[39;49;00m\r\n    \u001b[33m    errors : str, default 'strict'\u001b[39;49;00m\r\n    \u001b[33m        Specifies how encoding and decoding errors are to be handled.\u001b[39;49;00m\r\n    \u001b[33m        See the errors argument for :func:`open` for a full list\u001b[39;49;00m\r\n    \u001b[33m        of options.\u001b[39;49;00m\r\n    \u001b[33m    storage_options: StorageOptions = None\u001b[39;49;00m\r\n    \u001b[33m        Passed to _get_filepath_or_buffer\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    Returns the dataclass IOHandles\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[5.224274, "o", "        \u001b[90m# Windows does not default to utf-8. Set to utf-8 for a consistent behavior\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        encoding = encoding \u001b[95mor\u001b[39;49;00m \u001b[33m\"\u001b[39;49;00m\u001b[33mutf-8\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        errors = errors \u001b[95mor\u001b[39;49;00m \u001b[33m\"\u001b[39;49;00m\u001b[33mstrict\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# read_csv does not know whether the buffer is opened in binary/text mode\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[5.224312, "o", "        \u001b[94mif\u001b[39;49;00m _is_binary_mode(path_or_buf, mode) \u001b[95mand\u001b[39;49;00m \u001b[33m\"\u001b[39;49;00m\u001b[33mb\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m \u001b[95min\u001b[39;49;00m mode:\u001b[90m\u001b[39;49;00m\r\n            mode += \u001b[33m\"\u001b[39;49;00m\u001b[33mb\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# validate encoding and errors\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        codecs.lookup(encoding)\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m \u001b[96misinstance\u001b[39;49;00m(errors, \u001b[96mstr\u001b[39;49;00m):\u001b[90m\u001b[39;49;00m\r\n            codecs.lookup_error(errors)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# open URLs\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        ioargs = _get_filepath_or_buffer(\u001b[90m\u001b[39;49;00m\r\n            path_or_buf,\u001b[90m\u001b[39;49;00m\r\n"]
[5.224349, "o", "            encoding=encoding,\u001b[90m\u001b[39;49;00m\r\n            compression=compression,\u001b[90m\u001b[39;49;00m\r\n            mode=mode,\u001b[90m\u001b[39;49;00m\r\n            storage_options=storage_options,\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        handle = ioargs.filepath_or_buffer\u001b[90m\u001b[39;49;00m\r\n"]
[5.224361, "o", "        handles: \u001b[96mlist\u001b[39;49;00m[BaseBuffer]\u001b[90m\u001b[39;49;00m\r\n"]
[5.224431, "o", "    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# memory mapping needs to be the first step\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# only used for read_csv\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        handle, memory_map, handles = _maybe_memory_map(handle, memory_map)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        is_path = \u001b[96misinstance\u001b[39;49;00m(handle, \u001b[96mstr\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        compression_args = \u001b[96mdict\u001b[39;49;00m(ioargs.compression)\u001b[90m\u001b[39;49;00m\r\n        compression = compression_args.pop(\u001b[33m\"\u001b[39;49;00m\u001b[33mmethod\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Only for write methods\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m \u001b[33m\"\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m \u001b[95min\u001b[39;49;00m mode \u001b[95mand\u001b[39;49;00m is_path:\u001b[90m\u001b[39;49;00m\r\n            check_parent_directory(\u001b[96mstr\u001b[39;49;00m(handle))\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
[5.224451, "o", "        \u001b[94mif\u001b[39;49;00m compression:\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mif\u001b[39;49;00m compression != \u001b[33m\"\u001b[39;49;00m\u001b[33mzstd\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n                \u001b[90m# compression libraries do not like an explicit text-mode\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
