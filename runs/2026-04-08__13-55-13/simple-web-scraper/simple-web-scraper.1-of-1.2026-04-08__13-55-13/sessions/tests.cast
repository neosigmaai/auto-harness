[5.225194, "o", "            \u001b[94mif\u001b[39;49;00m ioargs.encoding \u001b[95mand\u001b[39;49;00m \u001b[33m\"\u001b[39;49;00m\u001b[33mb\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m \u001b[95min\u001b[39;49;00m ioargs.mode:\u001b[90m\u001b[39;49;00m\r\n                \u001b[90m# Encoding\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>               handle = \u001b[96mopen\u001b[39;49;00m(\u001b[90m\u001b[39;49;00m\r\n                    handle,\u001b[90m\u001b[39;49;00m\r\n                    ioargs.mode,\u001b[90m\u001b[39;49;00m\r\n"]
