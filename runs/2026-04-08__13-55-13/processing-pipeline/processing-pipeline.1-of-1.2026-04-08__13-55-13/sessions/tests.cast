[13.443237, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_correct_shebang\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test that generate_report.sh has a valid shebang.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mwith\u001b[39;49;00m \u001b[96mopen\u001b[39;49;00m(\u001b[33m\"\u001b[39;49;00m\u001b[33mgenerate_report.sh\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n            first_line = f.readline().strip()\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m first_line == \u001b[33m\"\u001b[39;49;00m\u001b[33m#!/bin/bash\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mgenerate_report.sh to be #!/bin/bash shebang\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: generate_report.sh to be #!/bin/bash shebang\u001b[0m\r\n\u001b[1m\u001b[31mE       assert '#!/bin/nonexistent' == '#!/bin/bash'\u001b[0m\r\n\u001b[1m\u001b[31mE         \u001b[0m\r\n\u001b[1m\u001b[31mE         \u001b[0m\u001b[91m- #!/bin/bash\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\u001b[0m\r\n\u001b[1m\u001b[31mE         \u001b[92m+ #!/bin/nonexistent\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:50: AssertionError\r\n\u001b[31m\u001b[1m___________________________________________________________________ test_pipeline_execution ____________________________________________________________________\u001b[0m\r\n\r\n"]
[13.44369, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_pipeline_execution\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test that the pipeline runs successfully end-to-end.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>       result = subprocess.run([\u001b[33m\"\u001b[39;49;00m\u001b[33m./run_pipeline.sh\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m], capture_output=\u001b[94mTrue\u001b[39;49;00m, text=\u001b[94mTrue\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n                 ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\u001b[90m\u001b[39;49;00m\r\n"]
