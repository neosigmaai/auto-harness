[13.44274, "o", "            content = f.read()\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m \u001b[33mb\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\\r\u001b[39;49;00m\u001b[33m\\n\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m \u001b[95min\u001b[39;49;00m content, \u001b[33m\"\u001b[39;49;00m\u001b[33mprocess_data.sh should not have DOS line endings\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: process_data.sh should not have DOS line endings\u001b[0m\r\n\u001b[1m\u001b[31mE       assert b'\\r\\n' not in b'#!/bin/bash\\r\\n# Data processing script\\r\\n\\r\\n# Check if input data exists\\r\\nif [ -f \"/data/output/raw_data.txt\" ]...ho \"Data processed successfully!\"\\r\\n    exit 0\\r\\nelse\\r\\n    echo \"Error: Input data not found!\"\\r\\n    exit 1\\r\\nfi'\u001b[0m\r\n\r\n"]
