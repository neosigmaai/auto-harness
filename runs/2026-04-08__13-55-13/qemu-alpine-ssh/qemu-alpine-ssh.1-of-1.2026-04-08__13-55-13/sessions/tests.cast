[10.887646, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_sshpass\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Reference the directory the agent operated in (the WORKDIR in the Docker env)\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        os.popen(\u001b[33m\"\u001b[39;49;00m\u001b[33mapt install -y sshpass\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m).read()\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        result = os.popen(\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m'\u001b[39;49;00m\u001b[33msshpass -p \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mpassword123\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m ssh -o \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mStrictHostKeyChecking=no\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            + \u001b[33m'\u001b[39;49;00m\u001b[33m-p 2222 root@localhost \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33muname -r\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        ).read()\u001b[90m\u001b[39;49;00m\r\n"]
[10.887666, "o", "    \u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m \u001b[33m\"\u001b[39;49;00m\u001b[33m6.6.4-1-lts\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m \u001b[95min\u001b[39;49;00m result, \u001b[33m\"\u001b[39;49;00m\u001b[33mOutput of ssh is wrong version\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
