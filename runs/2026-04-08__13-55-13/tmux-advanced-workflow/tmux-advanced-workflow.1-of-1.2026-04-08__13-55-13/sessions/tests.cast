[14.774584, "o", "\r\n"]
[14.79529, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_bug_fixed\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test that the script can be run successfully after the bug fix.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Create a temporary output file\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        output_file = \u001b[33m\"\u001b[39;49;00m\u001b[33m/app/project/data/test_output.csv\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Run the process_data.py script\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        result = subprocess.run(\u001b[90m\u001b[39;49;00m\r\n            [\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33mpython\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33m/app/project/src/process_data.py\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n"]
[14.795338, "o", "                \u001b[33m\"\u001b[39;49;00m\u001b[33m/app/project/data/input.csv\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                output_file,\u001b[90m\u001b[39;49;00m\r\n            ],\u001b[90m\u001b[39;49;00m\r\n            capture_output=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            text=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Check that the script executed successfully\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m result.returncode == \u001b[94m0\u001b[39;49;00m, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mScript failed with error: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mresult.stderr\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Check that the output file was created\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m os.path.exists(output_file), \u001b[33m\"\u001b[39;49;00m\u001b[33mOutput file was not created\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Check the content of the output file\u001b[39;49;00m\u001b[90"]
[14.795442, "o", "m\u001b[39;49;00m\r\n        \u001b[94mwith\u001b[39;49;00m \u001b[96mopen\u001b[39;49;00m(output_file, \u001b[33m\"\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n            lines = f.readlines()\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
[14.795466, "o", "        \u001b[90m# Verify that we have the expected number of processed lines\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# (should be 9, excluding the error)\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m \u001b[96mlen\u001b[39;49;00m(lines) == \u001b[94m9\u001b[39;49;00m, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mExpected 9 processed lines, got \u001b[39;49;00m\u001b[33m{\u001b[39;49;00m\u001b[96mlen\u001b[39;49;00m(lines)\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: Expected 9 processed lines, got 18\u001b[0m\r\n\u001b[1m\u001b[31mE       assert 18 == 9\u001b[0m\r\n\u001b[1m\u001b[31mE        +  where 18 = len(['2023-01-01,A001,16.30,First entry\\n', '\\n', '2023-01-02,A002,23.87,Normal operation\\n', '\\n', '2023-01-04,A004,34.45,High value\\n', '\\n', ...])\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:65: AssertionError\r\n"]
