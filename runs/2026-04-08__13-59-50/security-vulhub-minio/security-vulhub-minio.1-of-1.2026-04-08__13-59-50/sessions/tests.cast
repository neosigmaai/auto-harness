[22.003623, "o", "        output_file = \u001b[33m\"\u001b[39;49;00m\u001b[33m/app/result.txt\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        expected_outputs = [\u001b[33m\"\u001b[39;49;00m\u001b[33mminioadmin-vulhub\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mminioadmin\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m]\u001b[90m\u001b[39;49;00m\r\n>       actual_output = Path(output_file).read_text()\u001b[90m\u001b[39;49;00m\r\n                        ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\u001b[90m\u001b[39;49;00m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:10: \r\n_ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ \r\n\u001b[1m\u001b[31m/usr/lib/python3.12/pathlib.py\u001b[0m:1029: in read_text\r\n"]
[22.003683, "o", "    \u001b[0m\u001b[94mwith\u001b[39;49;00m \u001b[96mself\u001b[39;49;00m.open(mode=\u001b[33m'\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m, encoding=encoding, errors=errors) \u001b[94mas\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n         ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\u001b[90m\u001b[39;49;00m\r\n_ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ \r\n\r\nself = PosixPath('/app/result.txt'), mode = 'r', buffering = -1, encoding = 'locale', errors = None, newline = None\r\n\r\n"]
