[30.22693, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_hello_file_exists_example\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n        \u001b[96mopen\u001b[39;49;00m(\u001b[33m\"\u001b[39;49;00m\u001b[33mverify.sh\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mw\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m).write(\u001b[33m\"\"\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m#!/bin/bash\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m# This script tests the git server and web server setup\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m# Install curl for testing\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mapt-get update\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mDEBIAN_FRONTEND=noninteractive apt-get install -y curl expect\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m# Disable strict host key checking for localhost\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mmkdir -p ~/.ssh\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mecho \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mHost localhost\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    StrictHostKeyChecking no\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n"]
[30.226966, "o", "    \u001b[33m    UserKnownHostsFile=/dev/null\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m > ~/.ssh/config\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mchmod 600 ~/.ssh/config\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m# Use expect for handling interactive prompts\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mcat > git_test.exp << \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mEOF\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m#!/usr/bin/expect -f\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mset timeout 10\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m# Clone the repository\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mspawn git clone git@localhost:/git/server server-test\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mexpect \u001b[39;49;00m\u001b[33m{\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33myes/no\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m \u001b[39;49;00m\u001b[33m{\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m        send \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33myes\u001b[39;49;00m\u001b[33m\\r\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m        exp_continue\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    }\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mpassword:\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m \u001b[39;49;00m\u001b[33m{\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n"]
[30.226984, "o", "    \u001b[33m        send \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mpassword\u001b[39;49;00m\u001b[33m\\r\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    }\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m}\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mexpect eof\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n"]
[30.227014, "o", "    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m# Change directory, create file, add and commit\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mspawn bash -c \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mcd server-test && echo \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mhello world\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m > hello.html && git add hello.html && git config --local user.email \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mtest@example.com\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m && git config --local user.name \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mTest User\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m && git commit -m \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mAdd hello.html\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mexpect eof\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m# Push changes\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mspawn bash -c \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mcd server-test && git push origin master\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mexpect \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mpassword:\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n"]
[30.227058, "o", "    \u001b[33msend \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mpassword\u001b[39;49;00m\u001b[33m\\r\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mexpect eof\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33mexit\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mEOF\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33mchmod +x git_test.exp\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n"]
[30.227095, "o", "    \u001b[33m# Run the expect script\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m./git_test.exp\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m# Test if the file is accessible via web server\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mecho \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mTesting web server...\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33msleep 2 # Give some time for nginx to process\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33mif command -v curl &> /dev/null; then\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    echo \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mUsing curl to test web server...\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n"]
[30.227143, "o", "    \u001b[33m    HTTP_RESPONSE=$(curl -s -o /dev/null -w \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m%\u001b[39;49;00m\u001b[33m{http_code}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m http://localhost:8080/hello.html)\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    if [ \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m$HTTP_RESPONSE\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m = \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m200\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m ]; then\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m        CONTENT=$(curl -s http://localhost:8080/hello.html)\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m        echo \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mWeb server test successful (HTTP 200)\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m        echo \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mContent: $CONTENT\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m        if [ \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m$CONTENT\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m = \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mhello world\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m ]; then\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n"]
[30.227289, "o", "    \u001b[33m            echo \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m✅ TEST PASSED: Content matches expected output\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n"]
[30.227537, "o", "    \u001b[33m        else\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m            echo \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m❌ TEST FAILED: Content does not match expected output\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m            echo \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mExpected: \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mhello world\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m            echo \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mGot: \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m$CONTENT\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m        fi\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    else\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m        echo \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m❌ TEST FAILED: Web server returned HTTP $HTTP_RESPONSE\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    fi\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33melse\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    echo \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mUsing wget to test web server...\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    wget -q -O test_output.html http://localhost:8080/hello.html\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    if [ $? -eq 0 ]; then\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m        CONTENT=$(cat test_output.html)\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m        echo \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mWeb server test successful\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m        echo \u001b[39;