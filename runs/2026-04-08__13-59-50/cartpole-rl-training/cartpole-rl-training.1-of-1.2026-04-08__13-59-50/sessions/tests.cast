[4.877934, "o", "\u001b[1m\u001b[31mE       AssertionError: Model directory /app/trained_model does not exist\u001b[0m\r\n\u001b[1m\u001b[31mE       assert False\u001b[0m\r\n\u001b[1m\u001b[31mE        +  where False = exists()\u001b[0m\r\n\u001b[1m\u001b[31mE        +    where exists = PosixPath('/app/trained_model').exists\u001b[0m\r\n"]
