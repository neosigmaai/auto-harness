[6.158155, "o", "0m\r\n                )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Unrecognized Compression\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[94melse\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n                msg = \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mUnrecognized compression type: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mcompression\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mraise\u001b[39;49;00m \u001b[96mValueError\u001b[39;49;00m(msg)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m \u001b[96misinstance\u001b[39;49;00m(handle, \u001b[96mstr\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n            handles.append(handle)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94melif\u001b[39;49;00m \u001b[96misinstance\u001b[39;49;00m(handle, \u001b[96mstr\u001b[39;49;00m):\u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Check whether the filename is to be opened in binary mode.\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Binary mode does not support 'encoding' and 'newline'.\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mif\u001b[39;49;00m ioar"]
[6.158225, "o", "gs.encoding \u001b[95mand\u001b[39;49;00m \u001b[33m\"\u001b[39;49;00m\u001b[33mb\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m \u001b[95min\u001b[39;49;00m ioargs.mode:\u001b[90m\u001b[39;49;00m\r\n                \u001b[90m# Encoding\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>               handle = \u001b[96mopen\u001b[39;49;00m(\u001b[90m\u001b[39;49;00m\r\n                    handle,\u001b[90m\u001b[39;49;00m\r\n                    ioargs.mode,\u001b[90m\u001b[39;49;00m\r\n                    encoding=ioargs.encoding,\u001b[90m\u001b[39;49;00m\r\n                    errors=errors,\u001b[90m\u001b[39;49;00m\r\n                    newline=\u001b[33m\"\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                )\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE               FileNotFoundError: [Errno 2] No such file or directory: '/app/books.csv'\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/usr/local/lib/python3.13/site-packages/pandas/io/common.py\u001b[0m:926: FileNotFoundError\r\n\u001b[31m\u001b[1m______________________________________________________________________ test_data_accuracy ______________________________________________________________________\u001b[0m\r\n\r\n"]
