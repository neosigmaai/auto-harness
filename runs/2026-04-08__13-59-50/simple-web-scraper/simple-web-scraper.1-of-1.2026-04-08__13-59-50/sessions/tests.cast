[6.158627, "o", "\u001b[1m\u001b[31m/usr/local/lib/python3.13/site-packages/pandas/io/parsers/readers.py\u001b[0m:873: in read_csv\r\n"]
[6.158821, "o", "    \u001b[0m\u001b[94mreturn\u001b[39;49;00m _read(filepath_or_buffer, kwds)\u001b[90m\u001b[39;49;00m\r\n           ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31m/usr/local/lib/python3.13/site-packages/pandas/io/parsers/readers.py\u001b[0m:300: in _read\r\n"]
[6.159158, "o", "    \u001b[0mparser = TextFileReader(filepath_or_buffer, **kwds)\u001b[90m\u001b[39;49;00m\r\n             ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31m/usr/local/lib/python3.13/site-packages/pandas/io/parsers/readers.py\u001b[0m:1645: in __init__\r\n"]
[6.159455, "o", "    \u001b[0m\u001b[96mself\u001b[39;49;00m._engine = \u001b[96mself\u001b[39;49;00m._make_engine(f, \u001b[96mself\u001b[39;49;00m.engine)\u001b[90m\u001b[39;49;00m\r\n                   ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31m/usr/local/lib/python3.13/site-packages/pandas/io/parsers/readers.py\u001b[0m:1904: in _make_engine\r\n"]
[6.159644, "o", "    \u001b[0m\u001b[96mself\u001b[39;49;00m.handles = get_handle(\u001b[90m\u001b[39;49;00m\r\n_ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ \r\n\r\npath_or_buf = '/app/books.csv', mode = 'r'\r\n\r\n"]
[6.164491, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mget_handle\u001b[39;49;00m(\u001b[90m\u001b[39;49;00m\r\n        path_or_buf: FilePath | BaseBuffer,\u001b[90m\u001b[39;49;00m\r\n        mode: \u001b[96mstr\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n        *,\u001b[90m\u001b[39;49;00m\r\n        encoding: \u001b[96mstr\u001b[39;49;00m | \u001b[94mNone\u001b[39;49;00m = \u001b[94mNone\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n        compression: CompressionOptions | \u001b[94mNone\u001b[39;49;00m = \u001b[94mNone\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n        memory_map: \u001b[96mbool\u001b[39;49;00m = \u001b[94mFalse\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n        is_text: \u001b[96mbool\u001b[39;49;00m = \u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n        errors: \u001b[96mstr\u001b[39;49;00m | \u001b[94mNone\u001b[39;49;00m = \u001b[94mNone\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m"]
[6.164548, "o", "\r\n        storage_options: StorageOptions | \u001b[94mNone\u001b[39;49;00m = \u001b[94mNone\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n    ) -> IOHandles[\u001b[96mstr\u001b[39;49;00m] | IOHandles[\u001b[96mbytes\u001b[39;49;00m]:\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m\r\n    \u001b[33m    Get file handle for given path/buffer and mode.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    Parameters\u001b[39;49;00m\r\n    \u001b[33m    ----------\u001b[39;49;00m\r\n    \u001b[33m    path_or_buf : str or file handle\u001b[39;49;00m\r\n    \u001b[33m        File path or object.\u001b[39;49;00m\r\n"]
[6.164578, "o", "    \u001b[33m    mode : str\u001b[39;49;00m\r\n    \u001b[33m        Mode to open path_or_buf with.\u001b[39;49;00m\r\n    \u001b[33m    encoding : str or None\u001b[39;49;00m\r\n    \u001b[33m        Encoding to use.\u001b[39;49;00m\r\n    \u001b[33m    compression : str or dict, default 'infer'\u001b[39;49;00m\r\n    \u001b[33m        For on-the-fly compression of the output data. If 'infer' and 'path_or_buf'\u001b[39;49;00m\r\n    \u001b[33m        is path-like, then detect compression from the following extensions: '.gz',\u001b[39;49;00m\r\n"]
[6.164589, "o", "    \u001b[33m        '.bz2', '.zip', '.xz', '.zst', '.tar', '.tar.gz', '.tar.xz' or '.tar.bz2'\u001b[39;49;00m\r\n    \u001b[33m        (otherwise no compression).\u001b[39;49;00m\r\n"]
[6.16468, "o", "    \u001b[33m        Set to ``None`` for no compression.\u001b[39;49;00m\r\n    \u001b[33m        Can also be a dict with key ``'method'`` set\u001b[39;49;00m\r\n    \u001b[33m        to one of {``'zip'``, ``'gzip'``, ``'bz2'``, ``'zstd'``, ``'xz'``, ``'tar'``}\u001b[39;49;00m\r\n    \u001b[33m        and other key-value pairs are forwarded to\u001b[39;49;00m\r\n"]
[6.164693, "o", "    \u001b[33m        ``zipfile.ZipFile``, ``gzip.GzipFile``,\u001b[39;49;00m\r\n    \u001b[33m        ``bz2.BZ2File``, ``zstandard.ZstdCompressor``, ``lzma.LZMAFile`` or\u001b[39;49;00m\r\n    \u001b[33m        ``tarfile.TarFile``, respectively.\u001b[39;49;00m\r\n    \u001b[33m        As an example, the following could be passed for faster compression and to\u001b[39;49;00m\r\n    \u001b[33m        create a reproducible gzip archive:\u001b[39;49;00m\r\n    \u001b[33m        ``compression={'method': 'gzip', 'compresslevel': 1, 'mtime': 1}``.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m           May be a dict with key 'method' as compression mode\u001b[39;49;00m\r\n    \u001b[33m           and other keys as compression options if compression\u001b[39;49;00m\r\n    \u001b[33m           mode is 'zip'.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m           Passing compression options as keys in dict is\u001b[39;49;00m\r\n    \u001b[33m           supported for compression modes 'gzip', 'bz2', 'zstd' and 'zip'.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    memory_map : bool, default False\u001b[39;49;00m\r\n    \u001b[33m   "]
[6.164718, "o", "     See parsers._parser_params for more information. Only used by read_csv.\u001b[39;49;00m\r\n    \u001b[33m    is_text : bool, default True\u001b[39;49;00m\r\n    \u001b[33m        Whether the type of the content passed to the file/buffer is string or\u001b[39;49;00m\r\n    \u001b[33m        bytes. This is not the same as `\"b\" not in mode`. If a string content is\u001b[39;49;00m\r\n    \u001b[33m        passed to a binary file/buffer, a wrapper is inserted.\u001b[39;49;00m\r\n    \u001b[33m    errors : str, default 'strict'\u001b[39;49;00m\r\n    \u001b[33m        Specifies how encoding and decoding errors are to be handled.\u001b[39;49;00m\r\n    \u001b[33m        See the errors argument for :func:`open` for a full list\u001b[39;49;00m\r\n    \u001b[33m        of options.\u001b[39;49;00m\r\n    \u001b[33m    storage_options: StorageOptions = None\u001b[39;49;00m\r\n    \u001b[33m        Passed to _get_filepath_or_buffer\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    Returns the dataclass IOHandles\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Windows does not default to utf-8. Set to utf-8 for a c"]
[6.164801, "o", "onsistent behavior\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        encoding = encoding \u001b[95mor\u001b[39;49;00m \u001b[33m\"\u001b[39;49;00m\u001b[33mutf-8\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        errors = errors \u001b[95mor\u001b[39;49;00m \u001b[33m\"\u001b[39;49;00m\u001b[33mstrict\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# read_csv does not know whether the buffer is opened in binary/text mode\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m _is_binary_mode(path_or_buf, mode) \u001b[95mand\u001b[39;49;00m \u001b[33m\"\u001b[39;49;00m\u001b[33mb\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m \u001b[95min\u001b[39;49;00m mode:\u001b[90m\u001b[39;49;00m\r\n"]
[6.164817, "o", "            mode += \u001b[33m\"\u001b[39;49;00m\u001b[33mb\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# validate encoding and errors\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        codecs.lookup(encoding)\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m \u001b[96misinstance\u001b[39;49;00m(errors, \u001b[96mstr\u001b[39;49;00m):\u001b[90m\u001b[39;49;00m\r\n            codecs.lookup_error(errors)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# open URLs\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        ioargs = _get_filepath_or_buffer(\u001b[90m\u001b[39;49;00m\r\n            path_or_buf,\u001b[90m\u001b[39;49;00m\r\n            encoding=encoding,\u001b[90m\u001b[39;49;00m\r\n            compression=compression,\u001b[90m\u001b[39;49;00m\r\n            mode=mode,\u001b[90m\u001b[39;49;00m\r\n            storage_options=storage_options,\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        handle = ioargs.filepath_or_buffer\u001b[90m\u001b[39;49;00m\r\n"]
