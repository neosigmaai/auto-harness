[10.929586, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_original_sensitive_data_is_gone\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Verify original sensitive files and directory are deleted.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m SENSITIVE_FILE_1.exists(), (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mOriginal sensitive file \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mSENSITIVE_FILE_1\u001b[33m}\u001b[39;49;00m\u001b[33m still exists.\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n"]
