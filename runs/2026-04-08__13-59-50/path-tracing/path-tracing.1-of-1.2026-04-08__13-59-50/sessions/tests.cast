[9.86927, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_image_c_exists\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n        image_c_path = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/image.c\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m image_c_path.exists(), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mFile \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mimage_c_path\u001b[33m}\u001b[39;49;00m\u001b[33m does not exist\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: File /app/image.c does not exist\u001b[0m\r\n\u001b[1m\u001b[31mE       assert False\u001b[0m\r\n\u001b[1m\u001b[31mE        +  where False = exists()\u001b[0m\r\n\u001b[1m\u001b[31mE        +    where exists = PosixPath('/app/image.c').exists\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:11: AssertionError\r\n"]
[9.869326, "o", "\u001b[31m\u001b[1m_____________________________________________________________________ test_image_compiles ______________________________________________________________________\u001b[0m\r\n\r\n"]
[9.869753, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_image_compiles\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n        result = subprocess.run(\u001b[90m\u001b[39;49;00m\r\n            [\u001b[33m\"\u001b[39;49;00m\u001b[33mgcc\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-o\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m/app/image\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m/app/image.c\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-lm\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m],\u001b[90m\u001b[39;49;00m\r\n            capture_output=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            text=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m result.returncode == \u001b[94m0\u001b[39;49;00m, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mCompilation failed: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mresult.stderr\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: Compilation failed: cc1: fatal error: /app/image.c: No such file or directory\u001b[0m\r\n\u001b[1m\u001b[31mE         compilation terminated.\u001b[0m\r\n\u001b[1m\u001b[31mE         \u001b[0m\r\n\u001b[1m\u001b[31mE       assert 1 == 0\u001b[0m\r\n"]
[9.869941, "o", "\u001b[1m\u001b[31mE        +  where 1 = CompletedProcess(args=['gcc', '-o', '/app/image', '/app/image.c', '-lm'], returncode=1, stdout='', stderr='cc1: fatal error: /app/image.c: No such file or directory\\ncompilation terminated.\\n').returncode\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:20: AssertionError\r\n"]
[9.869978, "o", "\u001b[31m\u001b[1m________________________________________________________________ test_runs_and_produces_output _________________________________________________________________\u001b[0m\r\n\r\n"]
[9.870399, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_runs_and_produces_output\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Run the program\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        os.popen(\u001b[33m\"\u001b[39;49;00m\u001b[33mmv /app/image.ppm /app/back.ppm\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m).read()\u001b[90m\u001b[39;49;00m\r\n>       run_result = subprocess.run(\u001b[90m\u001b[39;49;00m\r\n            [\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/image\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m], capture_output=\u001b[94mTrue\u001b[39;49;00m, text=\u001b[94mTrue\u001b[39;49;00m, cwd=\u001b[33m\"\u001b[39;49;00m\u001b[33m/app\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:27: \r\n_ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ \r\n\u001b[1m\u001b[31m/usr/lib/python3.12/subprocess.py\u001b[0m:548: in run\r\n"]
[9.870663, "o", "    \u001b[0m\u001b[94mwith\u001b[39;49;00m Popen(*popenargs, **kwargs) \u001b[94mas\u001b[39;49;00m process:\u001b[90m\u001b[39;49;00m\r\n         ^^^^^^^^^^^^^^^^^^^^^^^^^^^\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31m/usr/lib/python3.12/subprocess.py\u001b[0m:1026: in __init__\r\n"]
[9.870811, "o", "    \u001b[0m\u001b[96mself\u001b[39;49;00m._execute_child(args, executable, preexec_fn, close_fds,\u001b[90m\u001b[39;49;00m\r\n_ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ \r\n\r\n"]
[9.870966, "o", "self = <Popen: returncode: 255 args: ['/app/image']>, args = ['/app/image'], executable = b'/app/image', preexec_fn = None, close_fds = True, pass_fds = ()\r\ncwd = '/app', env = None, startupinfo = None, creationflags = 0, shell = False, p2cread = -1, p2cwrite = -1, c2pread = 11, c2pwrite = 12, errread = 13\r\nerrwrite = 14, restore_signals = True, gid = None, gids = None, uid = None, umask = -1, start_new_session = False, process_group = -1\r\n\r\n"]
[9.876161, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92m_execute_child\u001b[39;49;00m(\u001b[96mself\u001b[39;49;00m, args, executable, preexec_fn, close_fds,\u001b[90m\u001b[39;49;00m\r\n                       pass_fds, cwd, env,\u001b[90m\u001b[39;49;00m\r\n                       startupinfo, creationflags, shell,\u001b[90m\u001b[39;49;00m\r\n                       p2cread, p2cwrite,\u001b[90m\u001b[39;49;00m\r\n                       c2pread, c2pwrite,\u001b[90m\u001b[39;49;00m\r\n                       errread, errwrite,\u001b[90m\u001b[39;49;00m\r\n                       restore_signals,\u001b[90m\u001b[39;49;00m\r\n                       gid, gids, uid, umask,\u001b[90m\u001b[39;49;00m\r\n                       start_new_session, process_group):\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Execute program (POSIX version)\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
