[9.87695, "o", "            child_exception_type = \u001b[96mgetattr\u001b[39;49;00m(\u001b[90m\u001b[39;49;00m\r\n                    builtins, exception_name.decode(\u001b[33m'\u001b[39;49;00m\u001b[33mascii\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m),\u001b[90m\u001b[39;49;00m\r\n                    SubprocessError)\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mif\u001b[39;49;00m \u001b[96missubclass\u001b[39;49;00m(child_exception_type, \u001b[96mOSError\u001b[39;49;00m) \u001b[95mand\u001b[39;49;00m hex_errno:\u001b[90m\u001b[39;49;00m\r\n                errno_num = \u001b[96mint\u001b[39;49;00m(hex_errno, \u001b[94m16\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mif\u001b[39;49;00m err_msg == \u001b[33m\"\u001b[39;49;00m\u001b[33mnoexec:chdir\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n                    err_msg = \u001b[33m\"\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                    \u001b[90m# The error must be from chdir(cwd).\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                    err_filename = cwd\u001b[90m\u001b[39;49;00m\r\n                \u001b[94melif\u001b[39;49;00m err_msg == \u001b[33m\"\u001b[39;49;00m\u001b[33mnoexec\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n                    err_msg = \u001b[33m\"\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                    err_filename = \u001b[94mNone\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                \u001b[94melse\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n                    err_filename = orig_executable\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mif\u001b[39;49;00m errno_num != \u001b[94m0\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n                    err_msg = os.strerror(errno_num)\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mif\u001b[39;49;00m err_filename \u001b[95mis\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m \u001b[94mNone\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n>                   \u001b[94mraise\u001b[39;49;00m child_exception_type(errno_num, err_msg, err_filename)\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE                   FileNotFoundError: [Errno 2] No such file or directory: '/app/image'\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/usr/lib/python3.12/subprocess.py\u001b[0m:1955: FileNotFoundError\r\n\u001b[31m\u001b[1m____________________________________________________________________ test_image_similarity _____________________________________________________________________\u001b[0m\r\n\r\n"]
[9.877373, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_image_similarity\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mimport\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[04m\u001b[96mnumpy\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[94mas\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[04m\u001b[96mnp\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mfrom\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[04m\u001b[96mPIL\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[94mimport\u001b[39;49;00m Image\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Load images using Pillow\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[9.877415, "o", ">       original = Image.open(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/image.ppm\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n                   ^^^^^^^^^^^^^^^^^^^^^^^^^^^^\u001b[90m\u001b[39;49;00m\r\n\r\n"]
[9.877439, "o", "\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:43: \r\n_ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ \r\n"]
[9.877461, "o", "\r\nfp = '/app/image.ppm', mode = 'r', formats = []\r\n\r\n"]
[9.87866, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mopen\u001b[39;49;00m(\u001b[90m\u001b[39;49;00m\r\n        fp: StrOrBytesPath | IO[\u001b[96mbytes\u001b[39;49;00m],\u001b[90m\u001b[39;49;00m\r\n        mode: Literal[\u001b[33m\"\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m] = \u001b[33m\"\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n        formats: \u001b[96mlist\u001b[39;49;00m[\u001b[96mstr\u001b[39;49;00m] | \u001b[96mtuple\u001b[39;49;00m[\u001b[96mstr\u001b[39;49;00m, ...] | \u001b[94mNone\u001b[39;49;00m = \u001b[94mNone\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n    ) -> ImageFile.ImageFile:\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m\r\n    \u001b[33m    Opens and identifies the given image file.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    This is a lazy operation; this function identifies the file, but\u001b[39;49;00m\r\n"]
[9.87868, "o", "    \u001b[33m    the file remains open and the actual image data is not read from\u001b[39;49;00m\r\n    \u001b[33m    the file until you try to process the data (or call the\u001b[39;49;00m\r\n    \u001b[33m    :py:meth:`~PIL.Image.Image.load` method).  See\u001b[39;49;00m\r\n    \u001b[33m    :py:func:`~PIL.Image.new`. See :ref:`file-handling`.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    :param fp: A filename (string), os.PathLike object or a file object.\u001b[39;49;00m\r\n    \u001b[33m       The file object must implement ``file.read``,\u001b[39;49;00m\r\n    \u001b[33m       ``file.seek``, and ``file.tell`` methods,\u001b[39;49;00m\r\n    \u001b[33m       and be opened in binary mode. The file object will also seek to zero\u001b[39;49;00m\r\n"]
[9.878807, "o", "    \u001b[33m       before reading.\u001b[39;49;00m\r\n    \u001b[33m    :param mode: The mode.  If given, this argument must be \"r\".\u001b[39;49;00m\r\n    \u001b[33m    :param formats: A list or tuple of formats to attempt to load the file in.\u001b[39;49;00m\r\n"]
[9.878857, "o", "    \u001b[33m       This can be used to restrict the set of formats checked.\u001b[39;49;00m\r\n    \u001b[33m       Pass ``None`` to try all supported formats. You can print the set of\u001b[39;49;00m\r\n    \u001b[33m       available formats by running ``python3 -m PIL`` or using\u001b[39;49;00m\r\n    \u001b[33m       the :py:func:`PIL.features.pilinfo` function.\u001b[39;49;00m\r\n    \u001b[33m    :returns: An :py:class:`~PIL.Image.Image` object.\u001b[39;49;00m\r\n    \u001b[33m    :exception FileNotFoundError: If the file cannot be found.\u001b[39;49;00m\r\n    \u001b[33m    :exception PIL.UnidentifiedImageError: If the image cannot be opened and\u001b[39;49;00m\r\n    \u001b[33m       identified.\u001b[39;49;00m\r\n    \u001b[33m    :exception ValueError: If the ``mode`` is not \"r\", or if a ``StringIO``\u001b[39;49;00m\r\n    \u001b[33m       instance is used for ``fp``.\u001b[39;49;00m\r\n    \u001b[33m    :exception TypeError: If ``formats`` is not ``None``, a list or a tuple.\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m mode != \u001b[33m\"\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n            msg = \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mbad mode \u001b[39;49;00m\u001b[33m{\u001b[39;49;00m\u001b[96mrepr\u001b[39;49;00m(mode)\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m  \u001b[90m# type: ignore[unreachable]\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mraise\u001b[39;49;00m \u001b[96mValueError\u001b[39;49;00m(msg)\u001b[90m\u001b[39;49;00m\r\n        \u001b[94melif\u001b[39;49;00m \u001b[96misinstance\u001b[39;49;00m(fp, io.StringIO):\u001b[90m\u001b[39;49;00m\r\n            msg = (  \u001b[90m# type: ignore[unreachable]\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33mStringIO cannot be used to open an image. \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33mBinary data must be used instead.\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mraise\u001b[39;49;00m \u001b[96mValueError\u001b[39;49;00m(msg)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m formats \u001b[95mis\u001b[39;49;00m \u001b[94mNone\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n            formats = ID\u001b[90m\u001b[39;49;00m\r\n        \u001b[94melif\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m \u001b[96misinstance\u001b[39;49;00m(formats, (\u001b[96mlist\u001b[39;49;00m, \u001b[96mtuple\u001b[39;49;00m)):\u001b[90m\u001b[39;49;00m\r\n"]
[9.878871, "o", "            msg = \u001b[33m\"\u001b[39;49;00m\u001b[33mformats must be a list or tuple\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m  \u001b[90m# type: ignore[unreachable]\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mraise\u001b[39;49;00m \u001b[96mTypeError\u001b[39;49;00m(msg)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        exclusive_fp = \u001b[94mFalse\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        filename: \u001b[96mstr\u001b[39;49;00m | \u001b[96mbytes\u001b[39;49;00m = \u001b[33m\"\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m is_path(fp):\u001b[90m\u001b[39;49;00m\r\n"]
[9.878983, "o", "            filename = os.fspath(fp)\u001b[90m\u001b[39;49;00m\r\n>           fp = builtins.open(filename, \u001b[33m\"\u001b[39;49;00m\u001b[33mrb\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n                 ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE           FileNotFoundError: [Errno 2] No such file or directory: '/app/image.ppm'\u001b[0m\r\n\r\n\u001b[1m\u001b[31m.venv/lib/python3.12/site-packages/PIL/Image.py\u001b[0m:3635: FileNotFoundError\r\n"]
