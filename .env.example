# Copy to .env and set OPENAI_API_KEY (required for patch generation).
OPENAI_API_KEY=your-openai-api-key-here

# Used by docker-compose for the tau2 data volume mount. For SWE-only workflows this
# can stay as a local empty-or-stub directory — create it with: mkdir -p data
TAU2_DATA_DIR=

# --- SWE-Bench (optional overrides; usually use experiment_config.yaml instead) ---
# SWE_DISABLE_LLM=1
# SWE_SKIP_HARNESS=1
# SWE_MAX_PATCH_TOKENS=8192
# SWE_USE_MAX_COMPLETION_TOKENS=1
# SWE_STUB_PATCH=
