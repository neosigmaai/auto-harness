# LLM API keys — set whichever your agent_model needs
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Terminal-Bench sandbox provider (set one)
E2B_API_KEY=
DAYTONA_API_KEY=

# WebArena site URLs — only the sites you use need to be set.
# The starter config uses Reddit/Postmill only.
# See: https://github.com/web-arena-x/webarena/blob/main/environment_docker/README.md
REDDIT=
SHOPPING=
SHOPPING_ADMIN=
GITLAB=
WIKIPEDIA=
MAP=
HOMEPAGE=

