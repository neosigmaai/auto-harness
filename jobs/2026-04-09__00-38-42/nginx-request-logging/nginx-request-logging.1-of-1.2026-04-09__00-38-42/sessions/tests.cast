[8.738665, "o", "            \u001b[90m# Other retry?\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mif\u001b[39;49;00m other \u001b[95mis\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m \u001b[94mNone\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n"]
