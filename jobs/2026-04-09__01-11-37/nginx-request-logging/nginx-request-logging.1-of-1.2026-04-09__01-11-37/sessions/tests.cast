[8.574109, "o", "        \u001b[94melse\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n            timeout = TimeoutSauce(connect=timeout, read=timeout)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mtry\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n"]
