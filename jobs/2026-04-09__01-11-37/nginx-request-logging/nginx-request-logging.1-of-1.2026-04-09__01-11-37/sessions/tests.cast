[8.588568, "o", ">           \u001b[94mraise\u001b[39;49;00m NewConnectionError(\u001b[90m\u001b[39;49;00m\r\n                \u001b[96mself\u001b[39;49;00m, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mFailed to establish a new connection: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00me\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            ) \u001b[94mfrom\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[04m\u001b[96me\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE           urllib3.exceptions.NewConnectionError: HTTPConnection(host='localhost', port=8080): Failed to establish a new connection: [Errno 111] Connection refused\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/usr/local/lib/python3.13/site-packages/urllib3/connection.py\u001b[0m:219: NewConnectionError\r\n\r\n\u001b[33mThe above exception was the direct cause of the following exception:\u001b[0m\r\n\r\nself = <requests.adapters.HTTPAdapter object at 0xffff9a2e6be0>, request = <PreparedRequest [GET]>, stream = False\r\ntimeout = Timeout(connect=None, read=None, total=None), verify = True, cert = None, proxies = OrderedDict()\r\n"]
