[8.602857, "o", "    \u001b[0m\u001b[96mself\u001b[39;49;00m._send_output(message_body, encode_chunked=encode_chunked)\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31m/usr/local/lib/python3.13/http/client.py\u001b[0m:1091: in _send_output\r\n"]
[8.602939, "o", "    \u001b[0m\u001b[96mself\u001b[39;49;00m.send(msg)\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31m/usr/local/lib/python3.13/http/client.py\u001b[0m:1035: in send\r\n"]
[8.603015, "o", "    \u001b[0m\u001b[96mself\u001b[39;49;00m.connect()\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31m/usr/local/lib/python3.13/site-packages/urllib3/connection.py\u001b[0m:331: in connect\r\n"]
[8.603193, "o", "    \u001b[0m\u001b[96mself\u001b[39;49;00m.sock = \u001b[96mself\u001b[39;49;00m._new_conn()\u001b[90m\u001b[39;49;00m\r\n                ^^^^^^^^^^^^^^^^\u001b[90m\u001b[39;49;00m\r\n_ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ \r\n\r\n"]
[8.603241, "o", "self = <HTTPConnection(host='localhost', port=8080) at 0xffff99ffe780>\r\n\r\n"]
[8.603982, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92m_new_conn\u001b[39;49;00m(\u001b[96mself\u001b[39;49;00m) -> socket.socket:\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Establish a socket connection and set nodelay settings on it.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    :return: New socket connection.\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mtry\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n            sock = connection.create_connection(\u001b[90m\u001b[39;49;00m\r\n                (\u001b[96mself\u001b[39;49;00m._dns_host, \u001b[96mself\u001b[39;49;00m.port),\u001b[90m\u001b[39;49;00m\r\n"]
