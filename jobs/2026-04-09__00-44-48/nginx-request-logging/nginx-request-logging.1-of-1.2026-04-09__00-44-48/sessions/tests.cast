[8.639936, "o", "\u001b[1m\u001b[31mE       assert 1 == 0\u001b[0m\r\n\u001b[1m\u001b[31mE        +  where 1 = CompletedProcess(args=['which', 'nginx'], returncode=1, stdout='', stderr='').returncode\u001b[0m\r\n\r\n"]
