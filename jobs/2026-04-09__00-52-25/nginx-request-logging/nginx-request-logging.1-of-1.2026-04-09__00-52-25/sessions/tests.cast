[8.555823, "o", "            sock = connection.create_connection(\u001b[90m\u001b[39;49;00m\r\n                (\u001b[96mself\u001b[39;49;00m._dns_host, \u001b[96mself\u001b[39;49;00m.port),\u001b[90m\u001b[39;49;00m\r\n                \u001b[96mself\u001b[39;49;00m.timeout,\u001b[90m\u001b[39;49;00m\r\n"]
