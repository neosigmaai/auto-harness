[8.673454, "o", "    \u001b[0mconn.request(\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31m/usr/local/lib/python3.13/site-packages/urllib3/connection.py\u001b[0m:500: in request\r\n"]
[8.673571, "o", "    \u001b[0m\u001b[96mself\u001b[39;49;00m.endheaders()\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31m/usr/local/lib/python3.13/http/client.py\u001b[0m:1331: in endheaders\r\n"]
[8.673697, "o", "    \u001b[0m\u001b[96mself\u001b[39;49;00m._send_output(message_body, encode_chunked=encode_chunked)\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31m/usr/local/lib/python3.13/http/client.py\u001b[0m:1091: in _send_output\r\n"]
[8.673787, "o", "    \u001b[0m\u001b[96mself\u001b[39;49;00m.send(msg)\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31m/usr/local/lib/python3.13/http/client.py\u001b[0m:1035: in send\r\n"]
[8.673855, "o", "    \u001b[0m\u001b[96mself\u001b[39;49;00m.connect()\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31m/usr/local/lib/python3.13/site-packages/urllib3/connection.py\u001b[0m:331: in connect\r\n"]
[8.674041, "o", "    \u001b[0m\u001b[96mself\u001b[39;49;00m.sock = \u001b[96mself\u001b[39;49;00m._new_conn()\u001b[90m\u001b[39;49;00m\r\n"]
[8.674049, "o", "                ^^^^^^^^^^^^^^^^\u001b[90m\u001b[39;49;00m\r\n"]
