[8.658077, "o", "    \u001b[0m\u001b[96mself\u001b[39;49;00m.send(msg)\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31m/usr/local/lib/python3.13/http/client.py\u001b[0m:1035: in send\r\n"]
