[8.675144, "o", "    \u001b[33m        data before giving up, as a float, or a :ref:`(connect timeout,\u001b[39;49;00m\r\n    \u001b[33m        read timeout) <timeouts>` tuple.\u001b[39;49;00m\r\n    \u001b[33m    :type timeout: float or tuple or urllib3 Timeout object\u001b[39;49;00m\r\n    \u001b[33m    :param verify: (optional) Either a boolean, in which case it controls whether\u001b[39;49;00m\r\n"]
[8.675151, "o", "    \u001b[33m        we verify the server's TLS certificate, or a string, in which case it\u001b[39;49;00m\r\n    \u001b[33m        must be a path to a CA bundle to use\u001b[39;49;00m\r\n"]
[8.675181, "o", "    \u001b[33m    :param cert: (optional) Any user-provided SSL certificate to be trusted.\u001b[39;49;00m\r\n"]
