[253.994224, "i", "cat > /etc/nginx/conf.d/benchmark-site.conf << 'EOF'\n# Rate limiting zone: 10 requests/sec per IP, stored in 10MB shared memory\nlimit_req_zone $binary_remote_addr zone=rate_limit:10m rate=10r/s;\n\n# Custom detailed log format\nlog_format benchmark_fmt '$time_local $request_method $status \"$http_user_agent\"';\n\nserver {\n    listen 8080;\n    server_name localhost;\n\n    # Document root for static files\n    root /var/www/html;\n    index index.html;\n\n    # Detailed access log using custom format\n    access_log /var/log/nginx/benchmark-access.log benchmark_fmt;\n\n    # Apply rate limiting to all requests\n    limit_req zone=rate_limit nodelay;\n\n    # Serve static files\n    location / {\n        try_files $uri $uri/ =404;\n    }\n\n    # Custom 404 error page\n    error_page 404 /404.html;\n    location = /404.html {\n        internal;\n    }\n}\nEOF; tmux wait -S done\r"]
[253.995315, "o", "cat > /etc/nginx/conf.d/benchmark-site.conf << 'EOF'\r\n\u001b[?2004l\r"]
