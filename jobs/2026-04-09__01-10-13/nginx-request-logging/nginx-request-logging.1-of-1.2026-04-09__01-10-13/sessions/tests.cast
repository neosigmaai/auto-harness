[8.65922, "o", "    \u001b[0mconn.request(\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31m/usr/local/lib/python3.13/site-packages/urllib3/connection.py\u001b[0m:500: in request\r\n"]
