[8.653776, "o", "    \u001b[90m\u001b[39;49;00m\r\n>           \u001b[94mraise\u001b[39;49;00m \u001b[96mConnectionError\u001b[39;49;00m(e, request=request)\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE           requests.exceptions.ConnectionError: HTTPConnectionPool(host='localhost', port=8080): Max retries exceeded with url: / (Caused by NewConnectionError(\"HTTPConnection(host='localhost', port=8080): Failed to establish a new connection: [Errno 111] Connection refused\"))\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/usr/local/lib/python3.13/site-packages/requests/adapters.py\u001b[0m:678: ConnectionError\r\n"]
